GRPC_ADDR=:50059
HEALTH_ADDR=:9099
LOG_LEVEL=info

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=af-scenarios
MINIO_USE_SSL=false
